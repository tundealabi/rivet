# Rivet — environment variables
# Copy to apps/api/.env when the API app is scaffolded

# Server
NODE_ENV=development
PORT=3000
CORS_ORIGIN=http://localhost:5173

# Database (matches docker-compose.yml defaults)
DATABASE_URL=postgresql://rivet:rivet@localhost:5432/rivet

# Redis (matches docker-compose.yml defaults)
REDIS_URL=redis://localhost:6379

# Auth — generate secrets for local dev (e.g. openssl rand -base64 32)
JWT_ACCESS_SECRET=change-me-access
JWT_REFRESH_SECRET=change-me-refresh
JWT_ACCESS_TTL_SECONDS=900
JWT_REFRESH_TTL_SECONDS=604800

# Logging
LOG_LEVEL=info
