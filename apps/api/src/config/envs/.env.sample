# APP
APP_CORS_ORIGINS="http://localhost:3000,http://localhost:8090" # CORS origins
APP_NODE_ENV=development # environment (development, production, test) — use production on staging too for Node/Express behavior
APP_ENABLE_DEV_FEATURES= # set to true to enable dev-only features (e.g. API docs, debug routes); leave unset in production
PORT=8090 # port to run the server on

# AUTH
AUTH_USER_ACCESS_TOKEN_EXPIRES_IN="15m" # access token expires in
AUTH_USER_ACCESS_TOKEN_SECRET="secret" # access token secret
AUTH_USER_REFRESH_TOKEN_EXPIRES_IN="7d" # refresh token expires in
AUTH_USER_REFRESH_TOKEN_SECRET="secret" # refresh token secret

# CLIENT
CLIENT_WEB_BASE_URL="http://localhost:3000" # public Rivet web app URL; used for emails and deep links

# DB
DATABASE_URL="postgresql://localhost:5432/rivet" # postgres connection string