{
  "moduleFileExtensions": ["js", "json", "ts"],
  "rootDir": ".",
  "testEnvironment": "node",
  "testRegex": ".e2e-spec.ts$",
  "moduleNameMapper": {
    "^@/(.*)$": "<rootDir>/../src/$1",
    "^@generated/prisma$": "<rootDir>/../generated/prisma/client",
    "^@generated/prisma/(.*)$": "<rootDir>/../generated/prisma/$1"
  },
  "transform": {
    "^.+\\.(t|j)s$": "ts-jest"
  }
}
